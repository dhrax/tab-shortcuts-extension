{
  "manifest_version": 3,
  "name": "Tab Shortcuts",
  "version": "0.1.0",
  "description": "Shortcuts to duplicate, mute and manage tabs in Brave.",
  "permissions": ["tabs", "storage", "clipboardWrite"],
  "action": {
    "default_title": "Tab Shortcuts",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      }
    },
    "duplicate-current-tab": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Duplicate current tab"
    },
    "toggle-mute-current-tab": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "Mute or unmute current tab"
    },
    "close-other-tabs": {
      "suggested_key": {
        "default": "Alt+Shift+X"
      },
      "description": "Close all tabs except current"
    },
    "mute-other-tabs": {
      "description": "Mute all other tabs"
    },
    "close-duplicate-tabs": {
      "description": "Close duplicate tabs by URL"
    },
    "close-tabs-to-left": {
      "description": "Close tabs to the left"
    },
    "close-tabs-to-right": {
      "description": "Close tabs to the right"
    },
    "toggle-pin-current-tab": {
      "description": "Pin or unpin current tab"
    }
  }
}   